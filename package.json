{
  "name": "plexui-docs",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "packages/ui",
    "packages/mcp",
    "packages/icons-lucide-outlined",
    "packages/icons-tabler-outlined",
    "packages/icons-hugeicons-outlined"
  ],
  "scripts": {
    "dev": "next dev",
    "dev:all": "npm run dev --workspace=packages/ui & next dev & wait",
    "dev:restart": "lsof -ti:3000 | xargs kill -9 2>/dev/null; next dev",
    "build": "npm run build:icon-catalogs && next build",
    "build:icon-catalogs": "node scripts/build-icon-catalogs.mjs",
    "fetch:icon-tags": "node scripts/fetch-icon-tags.mjs",
    "generate:plex-tags": "node scripts/generate-plex-tags.mjs",
    "classify:plex-filled": "node scripts/classify-plex-filled.mjs",
    "predev": "node scripts/build-icon-catalogs.mjs",
    "postinstall": "npm run build:ui",
    "build:ui": "npm run build --workspace=packages/ui",
    "build:mcp": "npm run build --workspace=packages/mcp",
    "generate:manifest": "node scripts/generate-mcp-manifest.mjs",
    "generate:llms": "node scripts/generate-llms-txt.mjs",
    "start": "next start",
    "lint": "eslint",
    "lint:docs-code": "node scripts/check-doc-code-duplicates.mjs",
    "publish:ui": "npm run build:ui && npm publish --access public --workspace=packages/ui",
    "publish:mcp": "npm run generate:manifest && npm run build:mcp && npm publish --access public --workspace=packages/mcp"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@hugeicons/core-free-icons": "^4.1.1",
    "@lucide/lab": "^0.1.2",
    "@plexui/ui": "*",
    "@tabler/icons": "^3.41.1",
    "@tanstack/react-virtual": "^3.13.24",
    "@types/mdx": "^2.0.13",
    "@vercel/analytics": "^1.6.1",
    "@vercel/speed-insights": "^1.3.1",
    "fumadocs-core": "^16.5.1",
    "fumadocs-mdx": "^14.2.6",
    "fumadocs-ui": "^16.5.1",
    "lucide-react": "^0.563.0",
    "lucide-static": "^0.563.0",
    "luxon": "^3.7.1",
    "next": "16.2.3",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/luxon": "^3.6.2",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.3",
    "postcss-functions": "^4.0.2",
    "tailwindcss": "^4",
    "typescript": "^5"
  },
  "overrides": {
    "minimatch@<3.1.3": "^3.1.3",
    "minimatch@>=9.0.0 <9.0.7": "^9.0.7",
    "flatted": "^3.4.2",
    "picomatch@<2.3.2": "^2.3.2",
    "picomatch@>=4.0.0 <4.0.4": "^4.0.4",
    "path-to-regexp": "^8.4.0"
  }
}

{
  "name": "plexui-video",
  "version": "0.0.1",
  "private": true,
  "description": "Remotion-based hero video for Plex UI",
  "scripts": {
    "dev": "remotion studio src/index.ts",
    "build": "remotion render src/index.ts HeroVideo out/plexui-hero.mp4 --concurrency=4",
    "build-vertical": "remotion render src/index.ts HeroVideoVertical out/plexui-hero-vertical.mp4 --concurrency=4",
    "build-gif": "remotion render src/index.ts HeroVideo out/plexui-hero.gif --codec=gif --concurrency=4",
    "preview": "remotion preview src/index.ts"
  },
  "dependencies": {
    "@remotion/cli": "^4.0.230",
    "@remotion/google-fonts": "^4.0.230",
    "@remotion/shapes": "^4.0.230",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "remotion": "^4.0.230"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "typescript": "^5.5.3"
  }
}
